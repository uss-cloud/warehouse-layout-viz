# 이 파일을 참고해 Streamlit Cloud 의 [App settings → Secrets] 에 붙여넣거나,
# 로컬 테스트 시 .streamlit/secrets.toml 로 저장(.gitignore 처리됨).
# 서비스계정 JSON 키의 값들을 그대로 옮기면 된다.

[gcp_service_account]
type = "service_account"
project_id = "your-project-id"
private_key_id = "xxxxxxxx"
private_key = "-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----\n"
client_email = "frozen-layout@your-project.iam.gserviceaccount.com"
client_id = "1234567890"
token_uri = "https://oauth2.googleapis.com/token"

[sheet]
id = "구글_시트_ID(URL의 /d/ 와 /edit 사이)"
tab = "재고"
